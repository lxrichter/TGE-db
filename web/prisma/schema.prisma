  @@index([updated_at], map: "idx_sources_updated_at")
  @@index([url], map: "idx_sources_url")
  @@index([visibility_code], map: "idx_sources_visibility")
  @@index([wordpress_post_id], map: "idx_sources_wordpress_post_id")
