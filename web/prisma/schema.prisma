  source_id              String                @db.Uuid
  project_id             String?               @db.Uuid
  operating_asset_id     String?               @db.Uuid
  company_id             String?               @db.Uuid
  evidence_type          String?
  evidence_note          String?
  confidence_status_code String                @default("unknown")
  created_at             DateTime              @default(now()) @db.Timestamptz(6)
  linked_field           String?
  claim_text             String?
  extracted_value        String?
  is_primary_evidence    Boolean               @default(false)
  reviewed_by_user_id    String?               @db.Uuid
  reviewed_at            DateTime?             @db.Timestamptz(6)
  updated_at             DateTime              @default(now()) @db.Timestamptz(6)
  companies              companies?            @relation(fields: [company_id], references: [company_id], onDelete: Cascade, onUpdate: NoAction)
  ref_estimate_statuses  ref_estimate_statuses @relation(fields: [confidence_status_code], references: [code], onDelete: NoAction, onUpdate: NoAction)
  operating_assets       operating_assets?     @relation(fields: [operating_asset_id], references: [operating_asset_id], onDelete: Cascade, onUpdate: NoAction)
  projects               projects?             @relation(fields: [project_id], references: [project_id], onDelete: Cascade, onUpdate: NoAction)
  app_users              app_users?            @relation(fields: [reviewed_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  sources                sources               @relation(fields: [source_id], references: [source_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([operating_asset_id], map: "idx_entity_sources_asset")
  @@index([company_id], map: "idx_entity_sources_company")
  @@index([project_id], map: "idx_entity_sources_project")
  @@index([source_id], map: "idx_entity_sources_source")
  @@index([confidence_status_code], map: "idx_entity_sources_confidence")
  @@index([linked_field], map: "idx_entity_sources_linked_field")
}

/// Per-relationship evidence links for company roles and company-to-company relationships.
/// This complements record-level entity_sources without replacing it.
/// It lets a source support a specific project role, operating-asset role, or ownership/group relationship.
model relationship_sources {
  relationship_source_id           String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_id                        String                         @db.Uuid
  company_project_link_id          String?                        @db.Uuid
  company_operating_asset_link_id  String?                        @db.Uuid
  company_relationship_id          String?                        @db.Uuid
  evidence_type                    String?
  linked_field                     String?
  claim_text                       String?
  extracted_value                  String?
  evidence_note                    String?
  confidence_status_code           String                         @default("unknown")
  is_primary_evidence              Boolean                        @default(false)
  reviewed_by_user_id              String?                        @db.Uuid
  reviewed_at                      DateTime?                      @db.Timestamptz(6)
  created_at                       DateTime                       @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime                       @default(now()) @db.Timestamptz(6)
  app_users                        app_users?                     @relation(fields: [reviewed_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  company_operating_asset_links    company_operating_asset_links? @relation(fields: [company_operating_asset_link_id], references: [company_operating_asset_link_id], onDelete: Cascade, onUpdate: NoAction)
  company_project_links            company_project_links?         @relation(fields: [company_project_link_id], references: [company_project_link_id], onDelete: Cascade, onUpdate: NoAction)
  company_relationships            company_relationships?         @relation(fields: [company_relationship_id], references: [company_relationship_id], onDelete: Cascade, onUpdate: NoAction)
  ref_estimate_statuses            ref_estimate_statuses          @relation(fields: [confidence_status_code], references: [code], onDelete: NoAction, onUpdate: NoAction)
  sources                          sources                        @relation(fields: [source_id], references: [source_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_project_link_id], map: "idx_relationship_sources_project_link")
  @@index([company_operating_asset_link_id], map: "idx_relationship_sources_asset_link")
  @@index([company_relationship_id], map: "idx_relationship_sources_company_relationship")
  @@index([source_id], map: "idx_relationship_sources_source")
  @@index([confidence_status_code], map: "idx_relationship_sources_confidence")
  @@index([linked_field], map: "idx_relationship_sources_linked_field")
}

